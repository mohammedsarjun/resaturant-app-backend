// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// In Prisma v7, the connection URL is passed via the driver adapter in code,
// not configured here. The datasource block only defines the provider type.
datasource db {
  provider = "postgresql"
}

model Restaurant {
  id        Int      @id @default(autoincrement())
  name      String
  address   String
  contact   String
  description String
  cuisine   String
  rating    Float
  tables    Int
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


