// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// In Prisma v7, the connection URL is passed via the driver adapter in code,
// not configured here. The datasource block only defines the provider type.
datasource db {
  provider = "postgresql"
}

model Cuisine {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  restaurants Restaurant[]
  status      String       @default("active")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Restaurant {
  id          Int      @id @default(autoincrement())
  name        String
  address     String
  contact     String
  description String
  cuisineId   Int?
  cuisine     Cuisine?  @relation(fields: [cuisineId], references: [id])
  rating      Float
  tables      Int
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


